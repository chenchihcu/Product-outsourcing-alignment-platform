# Supabase 雲端同步設定(選填)
# 留空 → App 以純 localStorage 離線模式運作(預設,行為與導入前一致)
# 填入 → 啟用真帳號登入、跨裝置雲端同步與即時協作
#
# 取得方式:Supabase Dashboard → 你的專案 → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 正式 RLS 驗證專用。請只填入專用測試帳號，且不要提交真實值。
ALLOW_PRODUCTION_SECURITY_AUDIT=
QA_RD_EMAIL=
QA_RD_PASSWORD=
QA_ENG_EMAIL=
QA_ENG_PASSWORD=
QA_QA_EMAIL=
QA_QA_PASSWORD=
QA_ADMIN_EMAIL=
QA_ADMIN_PASSWORD=
